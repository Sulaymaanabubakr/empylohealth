# Monorepo exclusions. These patterns are safe whether EAS evaluates them
# from the repo root or from the frontend app directory.

# Exclude sibling projects and large non-app folders when packaging from repo root.
admin-dashboard/
backend/
circles-site/
empylo-site/
brand_assets/
docs/
supabase backend/
Circle health App/

# VCS / editor / OS
.git/
.github/
.vscode/
.idea/
.DS_Store

# Package manager / install artifacts
node_modules/
**/node_modules/
.npm/
.npm-cache/

# Expo / Metro / local generated state
.expo/
.expo-shared/
dist/
web-build/
coverage/

# Local credentials and machine-specific files
.env
.env*.local
credentials/
credentials.json
*.jks
*.keystore
*.p8
*.mobileprovision
*.pem

# Android caches / build output
android/.gradle/
android/.cxx/
android/build/
android/app/build/
android/app/.cxx/
**/.gradle/
**/.cxx/

# iOS caches / build output
ios/Pods/
ios/build/

# Logs / archives / docs
npm-debug.log
yarn-debug.log
yarn-error.log
*.log
*.zip
*.tar
*.tar.gz
*.tgz
*.pdf

# Keep platform service config files available to the build.
!google-services.json
!**/google-services.json
!GoogleService-Info.plist
!**/GoogleService-Info.plist
