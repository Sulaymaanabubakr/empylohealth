# EAS resolves this app from the monorepo root, so keep the upload context
# on a strict allowlist: ship only the Expo app in /frontend.
*
!frontend/
!frontend/**

# Exclude local-only files inside the mobile app.
frontend/node_modules/
frontend/.git/
frontend/.expo/
frontend/.expo-shared/
frontend/dist/
frontend/web-build/
frontend/coverage/
frontend/.npm/
frontend/.npm-cache/
frontend/.DS_Store
frontend/.env
frontend/.env*.local
frontend/credentials/
frontend/credentials.json
frontend/*.jks
frontend/*.keystore
frontend/*.p8
frontend/*.mobileprovision
frontend/*.pem
frontend/android/.gradle/
frontend/android/.cxx/
frontend/android/build/
frontend/android/app/build/
frontend/android/app/.cxx/
frontend/ios/Pods/
frontend/ios/build/
frontend/**/*.log
frontend/npm-debug.log
frontend/yarn-debug.log
frontend/yarn-error.log

# Keep platform service config files available to the build.
!frontend/google-services.json
!frontend/**/google-services.json
!frontend/GoogleService-Info.plist
!frontend/**/GoogleService-Info.plist
