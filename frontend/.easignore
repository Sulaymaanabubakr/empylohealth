# Package manager / install artifacts
node_modules/
**/node_modules/
.npm/
.npm-cache/

# VCS / editor / OS
.git/
.github/
.vscode/
.idea/
.DS_Store

# Expo / Metro / local generated state
.expo/
.expo-shared/
dist/
web-build/
coverage/

# Logs
npm-debug.log
yarn-debug.log
yarn-error.log
*.log

# Local docs and references not needed for native builds
*.md
*.pdf

