.env
.env*.local
credentials/
credentials.json
*.jks
*.keystore
*.p8
*.mobileprovision
*.pem

# Android caches / build output
android/.gradle/
android/.cxx/
android/build/
android/app/build/
android/app/.cxx/
**/.gradle/
**/.cxx/

# iOS caches / build output
ios/Pods/
ios/build/

# Archives
**/*.zip
**/*.tar
**/*.tar.gz
**/*.tgz

