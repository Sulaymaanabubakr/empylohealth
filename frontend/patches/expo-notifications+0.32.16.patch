+  private suspend fun applyChatStyleIfNeeded(
+    builder: NotificationCompat.Builder,
+    content: INotificationContent
+  ): Boolean {
+    val remoteMessageData = getRemoteMessageData()
+    val type = remoteMessageData["type"]
+    if (type != "CHAT_MESSAGE") {
+      // Sets the text/contentText as the bigText to allow the notification to be expanded and the
+      // entire text to be viewed.
+      builder.setStyle(NotificationCompat.BigTextStyle().bigText(content.text))
+      return false
+    }
+
+    val senderName = remoteMessageData["senderName"]?.takeIf { it.isNotBlank() } ?: content.title ?: "Someone"
+    val chatName = remoteMessageData["chatName"]?.takeIf { it.isNotBlank() }
+    val isGroup = remoteMessageData["isGroup"]?.equals("true", ignoreCase = true) == true
+    val avatarBitmap = getAvatarBitmap(remoteMessageData["avatar"])
+
+    val senderPersonBuilder = Person.Builder()
+      .setName(senderName)
+      .setImportant(true)
+
+    avatarBitmap?.let {
+      senderPersonBuilder.setIcon(IconCompat.createWithBitmap(it))
+      builder.setLargeIcon(it)
+    }
+
+    val senderPerson = senderPersonBuilder.build()
+    val userPerson = Person.Builder()
+      .setName(context.applicationInfo.loadLabel(context.packageManager)?.toString() ?: "You")
+      .setImportant(false)
+      .build()
+
+    val style = NotificationCompat.MessagingStyle(userPerson)
+      .setGroupConversation(isGroup)
+      .addMessage(content.text ?: "", notification.originDate.time, senderPerson)
+
+    if (isGroup && !chatName.isNullOrBlank()) {
+      style.setConversationTitle(chatName)
+    }
+
+    builder.setStyle(style)
+    return avatarBitmap != null
+  }
+
+  private fun getRemoteMessageData(): Map<String, String> {
+    val trigger = notification.notificationRequest.trigger
+    if (trigger is FirebaseNotificationTrigger) {
+      return trigger.remoteMessage.data
+    }
+    return emptyMap()
+  }
+
