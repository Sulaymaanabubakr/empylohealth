{
  "expo": {
    "name": "Circles Health App",
    "slug": "circles-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "circlesapp",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.empylo.circlesapp",
      "associatedDomains": [
        "applinks:empylo.com",
        "applinks:www.empylo.com"
      ],
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "CFBundleDisplayName": "Circles App",
        "ITSAppUsesNonExemptEncryption": false,
        "NSFaceIDUsageDescription": "Use Face ID to quickly and securely unlock Circles Health App.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false
        },
        "UIBackgroundModes": [
          "remote-notification",
          "voip"
        ],
        "NSMicrophoneUsageDescription": "Empylo uses the microphone for voice and video calls.",
        "NSCameraUsageDescription": "Empylo uses the camera for video calls.",
        "NSPhotoLibraryUsageDescription": "Empylo uses your photo library so you can choose and upload a profile picture or circle photo."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#01a89e"
      },
      "package": "com.empylo.circlesapp",
      "permissions": [
        "RECORD_AUDIO",
        "POST_NOTIFICATIONS",
        "VIBRATE",
        "READ_PHONE_STATE",
        "CALL_PHONE"
      ],
      "googleServicesFile": "./google-services.json",
      "edgeToEdgeEnabled": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "empylo.com",
              "pathPrefix": "/invite"
            },
            {
              "scheme": "https",
              "host": "www.empylo.com",
              "pathPrefix": "/invite"
            },
            {
              "scheme": "https",
              "host": "empylo.com",
              "pathPrefix": "/ref"
            },
            {
              "scheme": "https",
              "host": "www.empylo.com",
              "pathPrefix": "/ref"
            },
            {
              "scheme": "https",
              "host": "empylo.com",
              "pathPrefix": "/circle"
            },
            {
              "scheme": "https",
              "host": "www.empylo.com",
              "pathPrefix": "/circle"
            },
            {
              "scheme": "https",
              "host": "empylo.com",
              "pathPrefix": "/a"
            },
            {
              "scheme": "https",
              "host": "www.empylo.com",
              "pathPrefix": "/a"
            },
            {
              "scheme": "https",
              "host": "empylo.com",
              "pathPrefix": "/r"
            },
            {
              "scheme": "https",
              "host": "www.empylo.com",
              "pathPrefix": "/r"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-apple-authentication",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Use Face ID to quickly and securely unlock Circles Health App."
        }
      ],
      "@daily-co/config-plugin-rn-daily-js",
      "./plugins/withVoipCallkit",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.433309283212-if0mi6urn71gv9n98d7e8m3bmtmkan8g"
        }
      ],
      "expo-audio",
      "expo-asset",
      "@react-native-community/datetimepicker",
      "react-native-iap"
    ],
    "extra": {
      "eas": {
        "projectId": "d5a69837-af96-49c2-ba42-1c11982c8dfb"
      }
    }
  }
}
