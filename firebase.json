{
  "functions": [
    {
      "source": "backend"
    }
  ],
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "database": {
    "rules": "database.rules.json"
  },
  "hosting": [
    {
      "target": "landing",
      "public": "web/dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "/apple-app-site-association",
          "function": "serveAppleAssociation"
        },
        {
          "source": "/invite/**",
          "function": "resolveDeepLink"
        },
        {
          "source": "/ref/**",
          "function": "resolveDeepLink"
        },
        {
          "source": "/circle/**",
          "function": "resolveDeepLink"
        },
        {
          "source": "/a/**",
          "function": "resolveDeepLink"
        },
        {
          "source": "/r/**",
          "function": "resolveDeepLink"
        },
        {
          "source": "/admin/**",
          "destination": "/index.html"
        },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "target": "admin",
      "public": "web/dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "redirects": [
        {
          "source": "/",
          "destination": "/admin",
          "type": 302
        }
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ]
}
